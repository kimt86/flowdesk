{
  "stack": {
    "framework": "nextjs",
    "language": "typescript",
    "styling": "tailwindcss",
    "database": "sqlite",
    "orm": "drizzle"
  },
  "build": {
    "typeCheck": "npx tsc --noEmit",
    "lint": "npm run lint",
    "build": "npm run build",
    "dev": "npm run dev"
  },
  "rules": {
    "maxFileLength": 500,
    "secretPatterns": [
      "PRIVATE_KEY",
      "SECRET",
      "PASSWORD",
      "API_KEY",
      "TOKEN"
    ],
    "antiPatterns": [
      "console.log",
      "any",
      "// TODO",
      "// HACK"
    ],
    "requiredFiles": [
      "package.json",
      "tsconfig.json",
      "next.config.mjs",
      "tailwind.config.js",
      "app/layout.tsx",
      "app/page.tsx"
    ]
  },
  "paths": {
    "source": ["app/", "components/", "lib/"],
    "config": ["package.json", "tsconfig.json", "next.config.mjs", "tailwind.config.js"],
    "docs": ["docs/"]
  }
}
