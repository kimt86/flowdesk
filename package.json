{
  "name": "flowdesk",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "desktop:icon": "node scripts/gen-icon.mjs",
    "desktop:build": "next build && node scripts/copy-standalone.mjs",
    "desktop:start": "electron .",
    "desktop:dir": "npm run desktop:build && electron-builder --win --dir",
    "desktop:pack": "npm run desktop:build && electron-builder --win nsis",
    "desktop:release": "npm run desktop:build && electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "@milkdown/core": "^7.20.0",
    "@milkdown/ctx": "^7.20.0",
    "@milkdown/plugin-history": "^7.20.0",
